# 🔒 NE JAMAIS COMMITER CE FICHIER — copie-le vers .env et remplis tes clés
# .env est déjà dans .gitignore ; ne force surtout pas son ajout avec -f
#
# OpenCode Go (abonnement payant — API utilisée par ApplyFit)
# Endpoint OpenAI-compatible : https://opencode.ai/zen/go/v1/chat/completions
OPENCODE_GO_API_KEY=sk-votre-cle-opencode-go-ici
OPENCODE_GO_MODEL=glm-5.2
# Certains modèles Go (ex: Kimi) n'acceptent qu'une température de 1.
# Laissez vide pour laisser le provider choisir sa valeur par défaut.
OPENCODE_GO_TEMPERATURE=0.1

PORT=3001
FRONTEND_URL=http://localhost:3001
# ANALYZE_TIMEOUT_MS=120000

# Configuration du logging
# NODE_ENV=development
# LOG_LEVEL=debug
# LOG_TO_CONSOLE=true
# LOG_TO_FILE=true
# LOG_MAX_FILES=14d
