# 🔒 NE JAMAIS COMMITER CE FICHIER — copie-le vers .env et remplis tes clés
# .env est déjà dans .gitignore ; ne force surtout pas son ajout avec -f
#
# Gemini via Google AI Studio (recommandé - vrai free tier)
# Obtiens ta clé gratuitement : https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_key_here
GEMINI_MODEL=gemini-2.0-flash

# Alternative : DeepSeek API (crédits gratuits au premier signup)
# DEEPSEEK_API_KEY=sk-votre-cle-ici
# DEEPSEEK_MODEL=deepseek-chat

PORT=3001
FRONTEND_URL=http://localhost:3001
